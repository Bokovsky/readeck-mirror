{
  "title_selectors": [
    "//meta[@property='og:title']/@content"
  ],
  "body_selectors": [
    "//main/article[1]",
    "//article[contains(@class, 'printversion')]"
  ],
  "date_selectors": [
    "//time/@datetime"
  ],
  "author_selectors": [
    "//meta[@name='author']/@content"
  ],
  "strip_selectors": [
    "//header",
    "//nav",
    "//div[@data-component=\"RecommendationBox\"]/parent::div",
    "//a-img"
  ],
  "strip_id_or_class": [
    "printversion__back-to-article",
    "printversion__logo"
  ],
  "strip_image_src": null,
  "native_ad_selectors": null,
  "tidy": false,
  "prune": false,
  "autodetect_on_failure": true,
  "single_page_link_selectors": [
