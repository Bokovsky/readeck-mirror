      "\u003cembetty-video type=\"footube\"\u003e\u003ciframe width=\"480\" height=\"360\" src=\"https://www.youtube.com/embed/"
    ],
    [
      "class=\"subheading\"",
      "class=\"wb-foo\""
    ]
  ],
