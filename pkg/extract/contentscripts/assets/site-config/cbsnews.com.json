{
  "title_selectors": [
    "//h1[@class=\"content__title\"]"
  ],
  "body_selectors": [
    "//section[@class=\"content__body\"]",
    "//section[contains(@class,\"content-updating-story__content-wrapper\")]"
  ],
  "date_selectors": [
    "//p[contains(@class,\"content__meta--timestamp\")]/time/@datetime"
  ],
  "author_selectors": [
    "//div[contains(@class,\"byline__author__link-wrapper\")]/a",
    "//a[contains(@class,\"byline__author__link\")]"
  ],
  "strip_selectors": [
    "//header[contains(@class,\"site-header__container\")]",
    "//div[contains(@class,\"top-ad-container\")]",
    "//div[contains(@class,\"ad-intromercial\")]",
    "//section[contains(@class,\"content__widget-wrapper\")]",
    "//div[@class=\"content__google\"]",
    "//section[contains(@class,\"post-newsletter-promo\")]",
    "//div[contains(@class,\"post-update__share\")]",
    "//ul[contains(@class,\"sharebar\")]",
    "//footer[contains(@class,\"content__footer\")]",
    "//aside[contains(@class,\"recirculation\")]",
    "//button"
  ],
  "strip_id_or_class": [
    "top-ad-container",
    "post-update__share",
    "sharebar",
    "content__google",
    "content__widget-wrapper",
    "post-newsletter-promo"
  ],
  "strip_image_src": null,
  "native_ad_selectors": null,
  "tidy": false,
  "prune": false,
  "autodetect_on_failure": true,
  "single_page_link_selectors": null,
  "next_page_link_selectors": null,
  "replace_strings": null,
  "http_headers": null,
  "tests": [
    {
      "url": "https://www.cbsnews.com/news/drunken-raccoon-virginia-liquor-store-bathroom-floor/",
      "contains": [
        "He fell through one of the ceiling tiles and went on a full-blown rampage, drinking everything."
      ]
    },
    {
      "url": "https://www.cbsnews.com/live-updates/iran-us-war-day-3-american-deaths-israel-gulf-allies-hit-missile-strikes/",
      "contains": [
        "has been dragged into the Iran war with and attacks on its territory and missile interceptions"
      ]
    }
  ]
}
