{
  "title_selectors": [
    "//meta[@property=\"og:title\"]/@content"
  ],
  "body_selectors": [
    "//div[contains(concat(' ',normalize-space(@class),' '),'story-content')]"
  ],
  "date_selectors": [
    "//meta[@property=\"article:published_time\"]/@content"
  ],
  "author_selectors": [
    "//a[contains(@href, '/author/')]"
  ],
  "strip_selectors": [
    "//div[contains(@class, 'story-heads')]/h1",
    "//div[contains(concat(' ',normalize-space(@class),' '),' post_tag ')]",
    "//div[contains(concat(' ',normalize-space(@class),' '),'tag-container')]",
    "//div[contains(concat(' ',normalize-space(@class),' '),'insert-post-ads')]",
    "//div[contains(concat(' ',normalize-space(@class),' '),'disqus')]",
    "//div[contains(concat(' ',normalize-space(@class),' '),'the-latest-footer')]",
    "//noscript"
  ],
  "strip_id_or_class": null,
  "strip_image_src": null,
  "native_ad_selectors": null,
  "tidy": false,
