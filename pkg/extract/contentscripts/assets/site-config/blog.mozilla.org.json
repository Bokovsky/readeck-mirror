{
  "title_selectors": [
    "//h1[@class='ft-c-single-post__title']"
  ],
  "body_selectors": [
    "//div[@class=\"ft-c-single-post__body\"]"
  ],
  "date_selectors": [
    "substring-before(substring-after(//script[@type=\"application/ld+json\"], '\"datePublished\":\"'), '\",\"dateModified\"')"
  ],
  "author_selectors": [
    "//a[contains(@class, 'author')]"
  ],
  "strip_selectors": null,
  "strip_id_or_class": null,
  "strip_image_src": null,
  "native_ad_selectors": null,
  "tidy": false,
  "prune": false,
  "autodetect_on_failure": true,
  "single_page_link_selectors": null,
  "next_page_link_selectors": null,
  "replace_strings": null,
  "http_headers": {
    "User-Agent": "Mozilla/5.0 (compatible; Googlebot/2.1; +http://www.google.com/bot.html)"
  },
