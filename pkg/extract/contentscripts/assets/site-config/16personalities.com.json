{
  "title_selectors": [
    "substring-before(//meta[@property='og:title']/@content , ' | 16Personalities')"
  ],
  "body_selectors": [
    "//div[contains(concat(' ',normalize-space(@class),' '),' article-content ')]",
    "//article",
    "substring-before(substring-after(//script[@type=\"application/ld+json\"], '\"articleBody\":\"'), '\",\"inLanguage\"')"
  ],
  "date_selectors": [
    "substring-before(substring-after(//script[@type=\"application/ld+json\"], '\"datePublished\":\"'), '\",\"dateModified\"')"
  ],
  "author_selectors": null,
  "strip_selectors": null,
  "strip_id_or_class": [
    "toc fixed",
    "toc bottom"
  ],
  "strip_image_src": null,
  "native_ad_selectors": null,
  "tidy": false,
  "prune": false,
  "autodetect_on_failure": true,
  "single_page_link_selectors": null,
  "next_page_link_selectors": null,
  "replace_strings": null,
  "http_headers": {
    "User-Agent": "Mozilla/5.0 (compatible; Googlebot/2.1; +http://www.google.com/bot.html)"
  },
  "tests": [
    {
      "url": "https://www.16personalities.com/articles/our-theory",
      "contains": [
        "“What do these letters mean?” We are of course referring to those mysterious acronyms like INTJ-A, ENFP-T, or ESTJ-A"
      ]
    },
    {
      "url": "https://www.16personalities.com/intj-parents",
      "contains": [
        "are known for their rationality and self-control"
      ]
    }
  ]
}
