msgstr "Finu instaladon"

#: assets/templates/auth/recover.jet.html:9
msgid "Password recovery"
msgstr "Pasvorta reakiro"

#: assets/templates/auth/recover.jet.html:20
msgid "No worries, it happens to anyone."
msgstr "Ne zorgu, ĝi okazas al iu ajn."

#: assets/templates/auth/recover.jet.html:21
msgid ""
"\n"
"        Please provide the email address you used to create\n"
"        your account and we'll send you a message with a link\n"
"        to recover your password.\n"
"      "
msgstr ""
"\n"
"        Bonvolu doni la retpoŝtan adreson, kiun vi uzis por krei\n"
"        vian konton, kaj ni sendos al vi mesaĝon kun ligilo\n"
"        por restarigi vian pasvorton.\n"
"      "

#: assets/templates/auth/recover.jet.html:31
