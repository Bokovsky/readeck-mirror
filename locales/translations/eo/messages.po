msgid "must be at least 8 characters long"
msgstr "devas esti almenaŭ 8 signoj longaj"

#: assets/templates/auth/onboarding.jet.html:38
msgid "Please note:"
msgstr "Bonvolu noti:"

#: assets/templates/auth/onboarding.jet.html:39
msgid ""
"\n"
"  Your email address is optional and will never leave this installation.\n"
"  It will never be collected, transferred or sold.\n"
"  It will <strong>only</strong> be used, should you need it, for password recovery and internal notifications.\n"
"  "
msgstr ""
"\n"
"  Via retpoŝta adreso estas laŭvola kaj neniam forlasos ĉi tiun instalaĵon.\n"
"  Ĝi neniam estos kolektita, transdonita aŭ vendita.\n"
"  Ĝi estos uzata <strong>nur</strong> se vi bezonos ĝin, por pasvorta reakiro kaj internaj sciigoj.\n"
"  "

#: assets/templates/auth/onboarding.jet.html:46
