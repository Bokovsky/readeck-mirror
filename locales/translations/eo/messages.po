#: assets/templates/auth/recover.jet.html:37
#, python-format
msgid ""
"\n"
"        We have sent an email to\n"
"        <strong>%s</strong>\n"
"        with further instructions.\n"
"      "
msgstr ""
"\n"
"        Ni sendis retleteron al\n"
"        <strong>%s</strong>\n"
"        kun pliaj instrukcioj.\n"
"      "

