#: assets/templates/auth/recover.jet.html:54
#: assets/templates/profile/password.jet.html:31
msgid "must be at least 8 characters long"
msgstr "трябва да е с дължина поне 8 символа"

#: assets/templates/auth/onboarding.jet.html:38
msgid "Please note:"
msgstr "Обърнете внимание:"

#: assets/templates/auth/onboarding.jet.html:39
msgid ""
"\n"
"  Your email address is optional and will never leave this installation.\n"
"  It will never be collected, transferred or sold.\n"
"  It will <strong>only</strong> be used, should you need it, for password recovery and internal notifications.\n"
"  "
msgstr ""
"\n"
"  Вашият имейл адрес е опционален и никога няма да напусне тази инсталация.\n"
"  Той никога няма да бъде събиран, прехвърлян или продаван.\n"
"  Ще бъде използван <strong>само</strong> при нужда от възстановяване на паролата и вътрешни уведомления.\n"
"  "

#: assets/templates/auth/onboarding.jet.html:46
msgid "Finish installation"
msgstr "Завършете инсталирането"

#: assets/templates/auth/recover.jet.html:9
msgid "Password recovery"
msgstr "Възстановяване на парола"

#: assets/templates/auth/recover.jet.html:20
msgid "No worries, it happens to anyone."
msgstr "Няма проблем, случва се на всеки."

#: assets/templates/auth/recover.jet.html:21
msgid ""
"\n"
"        Please provide the email address you used to create\n"
"        your account and we'll send you a message with a link\n"
"        to recover your password.\n"
"      "
msgstr ""
"\n"
"        Моля, предоставете имейл адреса, който сте използвали за създаване\n"
"        на вашия акаунт, и ще ви изпратим съобщение с връзка\n"
"        за възстановяване на паролата.\n"
"      "

#: assets/templates/auth/recover.jet.html:31
msgid "Send me a recovery link"
msgstr "Изпратете ми връзка за възстановяване"

#: assets/templates/auth/recover.jet.html:32
#: assets/templates/auth/recover.jet.html:56
msgid "Cancel and go back to sign in"
msgstr "Отказ и връщане към входа"

#: assets/templates/auth/recover.jet.html:36
msgid "Almost there!"
msgstr "Почти сте там!"

#: assets/templates/auth/recover.jet.html:37
#, python-format
msgid ""
"\n"
"        We have sent an email to\n"
"        <strong>%s</strong>\n"
"        with further instructions.\n"
"      "
msgstr ""
"\n"
"        Изпратихме имейл до\n"
"        <strong>%s</strong>\n"
"        с допълнителни инструкции.\n"
"      "

